# ==========================================================
# Rehearsal Block - SvelteKit environment variables
# Copy this to .env and fill in real values from the dashboards.
# NEVER commit .env to git (it's gitignored for a reason).
#
# For Netlify deploys, set these in the site's Build & Deploy
# environment settings, not in a committed .env file.
# ==========================================================

# --- Supabase ---
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
# Connection pooling URL for server-side queries. Supabase Free has a
# 60-connection Postgres limit; Netlify functions each open a connection
# without pooling, which hits the ceiling at moderate concurrent load.
# The pgbouncer URL pools those down. Look for it in the Supabase dashboard
# under Settings -> Database -> Connection pooling.
SUPABASE_POOLED_URL=postgresql://postgres:...@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# --- Stripe ---
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
PUBLIC_STRIPE_PRICE_ID=price_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Cloudflare R2 (Phase 1 of paid version plan) ---
# Primary blob storage for show documents, archives, share snapshots,
# conflict snapshots, and backups. Free tier: 10GB storage, 1M writes/mo,
# 10M reads/mo, zero egress. See Cloudflare dashboard -> R2 -> Manage API
# Tokens to generate credentials.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Private bucket for owner-only show data. Dev points to the -dev variant
# so local testing never pollutes production data.
R2_BUCKET_NAME=rehearsal-block-shows-dev
# Public-read bucket for actor-facing share + conflict snapshots. Created
# in Phase 5. Custom domain attached via Cloudflare dashboard for CDN
# direct serving at share.rehearsalblock.com.
R2_PUBLIC_BUCKET_NAME=rehearsal-block-public
R2_PUBLIC_DOMAIN=share.rehearsalblock.com

# --- Sentry (Phase 7 of paid version plan) ---
# Error monitoring, Free tier (5k events/month). Project DSN from
# Sentry dashboard -> Settings -> Projects -> rehearsal-block -> SDK Setup.
PUBLIC_SENTRY_DSN=https://xxxxx@oXXXXXX.ingest.sentry.io/XXXXXX
# For source map upload at build time. Used by the Sentry Vite plugin only
# in production builds. Safe to leave blank in dev.
SENTRY_AUTH_TOKEN=sntrys_...

# --- Site ---
PUBLIC_SITE_URL=http://localhost:5173
